---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="404 | Trim Studio">
  <section class="min-h-[70vh] flex items-center justify-center bg-ink">
    <div class="container-site text-center">
      <p class="font-display text-[8rem] font-semibold text-cream/10 leading-none select-none">404</p>
      <h1 class="font-display text-2xl text-cream mt-[-2rem] mb-4">ページが見つかりません</h1>
      <p class="text-xs text-cream/40 font-body mb-10">
        お探しのページは存在しないか、移動または削除された可能性があります。
      </p>
      <a href="/" class="btn-outline-light">トップページへ戻る</a>
    </div>
  </section>
</Layout>
