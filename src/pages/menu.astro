---
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/Icon.astro";
import { SITE } from "@/lib/config";
import { getItemsByCategory } from "@/lib/pricing";

const sections = [
  {
    id: "cut",
    label: "Cut",
    title: "カット",
    image: "https://images.unsplash.com/photo-1622286342621-4bd786c2447c?auto=format&fit=crop&w=800&q=80",
    items: getItemsByCategory("cut"),
  },
  {
    id: "shave",
    label: "Shave",
    title: "シェービング",
    image: "https://images.unsplash.com/photo-1599351431202-1e0f0137899a?auto=format&fit=crop&w=800&q=80",
    items: getItemsByCategory("shave"),
  },
  {
    id: "set",
    label: "Set",
    title: "セットメニュー",
    image: "https://images.unsplash.com/photo-1503951914875-452162b0f3f1?auto=format&fit=crop&w=800&q=80",
    items: getItemsByCategory("set"),
  },
  {
    id: "other",
    label: "Other",
    title: "その他",
    image: "https://images.unsplash.com/photo-1585747860715-2ba37e788b70?auto=format&fit=crop&w=800&q=80",
    items: getItemsByCategory("other"),
  },
];
---

<Layout
  title="Menu | Trim Studio"
  description="Trim Studio のメニュー・料金一覧。カット・シェービングなど各種メニューをご用意しております。"
>

  <!-- ━━━━━━━━ ページヘッダー ━━━━━━━━ -->
  <section class="relative py-24 md:py-32 bg-ink overflow-hidden">
    <!-- 背景画像 -->
    <div class="absolute inset-0 opacity-[0.15]">
      <img
        src="https://images.unsplash.com/photo-1621605815971-fbc98d665033?auto=format&fit=crop&w=1920&q=80"
        alt=""
        class="w-full h-full object-cover"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to right, #1c1917, rgba(28,25,23,0.6));"></div>
    </div>

    <!-- 透かし文字 -->
    <span class="watermark-dark absolute right-[-2%] top-1/2 -translate-y-1/2 pointer-events-none hidden lg:block">MENU</span>

    <div class="container-site relative z-10">
      <div class="flex items-end justify-between gap-8">
        <div class="animate-fade-up">
          <span class="section-label text-gold/55">Services & Pricing</span>
          <h1 class="font-display text-6xl md:text-7xl text-cream font-semibold leading-none">Menu</h1>
        </div>
        <div class="hidden md:flex flex-col items-end gap-2 text-right shrink-0">
          <p class="text-[11px] text-cream/28 font-body tracking-wider">料金はすべて税込</p>
          <p class="text-[11px] text-cream/28 font-body tracking-wider">All prices incl. tax</p>
        </div>
      </div>

      <!-- ページ内ナビ -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 mt-10 pt-8 border-t border-cream/8">
        {sections.map(s => (
          <a
            href={`#${s.id}`}
            class="text-[10px] tracking-widest2 uppercase text-cream/38 hover:text-gold transition-colors duration-200 font-body"
          >
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━ メニューセクション（交互レイアウト） ━━━━━━━━ -->
  <section class="sec bg-cream">
    <div class="container-site">
      <div class="space-y-20 md:space-y-28">

        {sections.map((section, i) => (
          <div id={section.id}>
            <!-- グリッド：奇数は画像左、偶数は画像右 -->
            <div class={`grid grid-cols-12 gap-6 md:gap-10 items-start`}>

              <!-- 画像（sm以上のみ） -->
              <div class={`col-span-12 md:col-span-4 ${i % 2 === 1 ? 'md:order-last' : ''} reveal-left`}>
                <div class="relative overflow-hidden group" style="aspect-ratio: 4/5;">
                  <img
                    src={section.image}
                    alt={section.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    loading="lazy"
                  />
                  <!-- カテゴリーオーバーレイ -->
                  <div class="absolute bottom-0 left-0 right-0 p-4" style="background: linear-gradient(to top, rgba(28,25,23,0.65), transparent);">
                    <span class="text-[9px] tracking-widest2 text-gold uppercase font-body">{section.label}</span>
                  </div>
                  <!-- 装飾フレーム（非対称） -->
                  {i % 2 === 0
                    ? <div class="absolute -bottom-3 -right-3 w-3/4 h-3/4 border border-gold/18 pointer-events-none"></div>
                    : <div class="absolute -bottom-3 -left-3 w-3/4 h-3/4 border border-gold/18 pointer-events-none"></div>
                  }
                </div>
              </div>

              <!-- コンテンツ -->
              <div class={`col-span-12 md:col-span-8 ${i % 2 === 1 ? 'md:order-first' : ''} reveal-right`}>
                <!-- セクション見出し -->
                <div class="flex items-center gap-4 mb-8">
                  <h2 class="font-display text-3xl text-ink">{section.title}</h2>
                  <span class="flex-1 h-px bg-ink/10"></span>
                  <span class="text-[9px] tracking-widest2 uppercase text-gold font-body">{section.label}</span>
                </div>

                <!-- アイテムリスト -->
                <div class="space-y-3">
                  {section.items.map(item => (
                    <div class="group flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-5 px-6 bg-cream-dark hover:bg-cream border-l-2 border-transparent hover:border-gold transition-all duration-300">
                      <div class="flex-1">
                        <p class="font-display text-xl text-ink mb-1">{item.name}</p>
                        <p class="text-xs text-ink-muted font-body leading-relaxed">{item.desc}</p>
                      </div>
                      <div class="flex-shrink-0 sm:text-right">
                        <p class="font-display text-3xl text-gold font-semibold">{item.priceDisplay}</p>
                        {item.variablePrice && (
                          <p class="text-[10px] text-ink-muted font-body mt-0.5">カット料金別途</p>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>

            </div>
          </div>
        ))}

      </div>
    </div>
  </section>


  <!-- ━━━━━━━━ 注意事項 ━━━━━━━━ -->
  <section class="py-20 bg-ink relative overflow-hidden">
    <span class="watermark-dark absolute right-[-4%] top-1/2 -translate-y-1/2 pointer-events-none hidden lg:block">NOTE</span>

    <div class="container-site relative z-10">
      <div class="grid grid-cols-12 gap-8 items-start">

        <div class="col-span-12 md:col-span-4 reveal">
          <span class="section-label text-gold/55">Notice</span>
          <h2 class="section-title-light">ご利用に<br/>あたって</h2>
          <div class="w-8 h-px mt-5" style="background-color: rgba(200,169,110,0.45);"></div>
        </div>

        <div class="col-span-12 md:col-span-8 reveal-right delay-200">
          <ul class="space-y-0">
            {[
              "料金はすべて税込価格です。",
              "初めてのお客様はカウンセリングにお時間をいただく場合があります。",
              "髪質・状態により料金が変動する場合がございます。",
              "ご予約優先ですが、空きがあればご予約なしでもご案内できます。",
              "ご不明な点はお気軽にお問い合わせください。",
            ].map(text => (
              <li class="flex items-start gap-4 py-4 border-b border-cream/8 last:border-0">
                <span class="text-gold mt-0.5 flex-shrink-0">
                  <Icon name="chevron-right" class="w-4 h-4" />
                </span>
                <span class="text-sm text-cream/65 font-body leading-relaxed">{text}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━ CTA ━━━━━━━━ -->
  <section class="py-20 bg-cream-dark">
    <div class="container-site text-center reveal">
      <span class="section-label">Reservation</span>
      <h2 class="section-title mb-3">ご予約・お問い合わせ</h2>
      <div class="divider"></div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a
          href={SITE.telHref}
          class="inline-flex items-center justify-center gap-2 btn-outline-dark"
        >
          <Icon name="phone" class="w-4 h-4" />
          {SITE.tel}
        </a>
        <a href="/contact" class="btn-dark">Contact Form</a>
      </div>
    </div>
  </section>

</Layout>
