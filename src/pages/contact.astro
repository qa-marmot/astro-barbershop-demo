---
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/Icon.astro";
import { SITE } from "@/lib/config";
---

<Layout
  title="Contact | Trim Studio"
  description="Trim Studio へのご予約・お問い合わせはこちら。お気軽にご連絡ください。"
>
  <!-- ページヘッダー -->
  <section class="py-20 md:py-24 bg-ink">
    <div class="container-site">
      <span class="section-label text-gold/70">Get in Touch</span>
      <h1 class="font-display text-5xl md:text-6xl text-cream font-semibold leading-tight">Contact</h1>
    </div>
  </section>

  <!-- お問い合わせ方法 -->
  <section class="sec bg-cream">
    <div class="container-site">
      <div class="max-w-3xl mx-auto">

        <p class="text-sm text-ink-muted font-body text-center mb-14 leading-relaxed">
          ご予約・ご質問など、お気軽にお問い合わせください。<br/>
          お電話が繋がらない場合は折り返しご連絡いたします。
        </p>

        <!-- 2カラム: 電話 / フォーム -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">

          <!-- 電話 -->
          <div class="bg-ink p-8 text-center">
            <div class="w-12 h-12 mx-auto mb-5 flex items-center justify-center border border-gold/40 text-gold">
              <Icon name="phone" class="w-5 h-5" />
            </div>
            <h2 class="font-display text-xl text-cream mb-2">電話予約</h2>
            <p class="text-[10px] tracking-wider text-cream/40 font-body uppercase mb-5">Phone Reservation</p>
            <p class="font-display text-2xl text-gold mb-1">{SITE.tel}</p>
            <p class="text-[11px] text-cream/50 font-body leading-relaxed mb-6">
              火〜金  10:00 – 20:00<br/>
              土・日  10:00 – 19:00<br/>
              <span class="text-cream/30">定休日：月曜日</span>
            </p>
            <a href={SITE.telHref} class="btn-outline-light text-[11px]">電話をかける</a>
          </div>

          <!-- フォーム -->
          <div class="bg-cream-dark border border-ink/10 p-8 text-center">
            <div class="w-12 h-12 mx-auto mb-5 flex items-center justify-center border border-gold/40 text-gold">
              <Icon name="mail" class="w-5 h-5" />
            </div>
            <h2 class="font-display text-xl text-ink mb-2">フォーム</h2>
            <p class="text-[10px] tracking-wider text-ink-muted font-body uppercase mb-5">Online Form</p>
            <p class="text-xs text-ink-muted font-body leading-relaxed mb-6">
              24時間受付中<br/>
              2営業日以内にご返信いたします
            </p>
            <a href="#form" class="btn-outline-dark text-[11px]">フォームへ進む</a>
          </div>
        </div>

        <!-- フォーム埋め込みエリア -->
        <div id="form" class="bg-cream-dark border border-ink/10 p-8 md:p-10">
          <h2 class="font-display text-2xl text-ink text-center mb-8">お問い合わせフォーム</h2>

          <!--
            【設定方法】
            1. Google フォームを作成し「送信 → 埋め込み」からコードを取得
            2. 下記コメントを解除して YOUR_GOOGLE_FORM_ID を差し替え
            セキュリティ: CSP に https://docs.google.com を許可済み。
            sandbox 属性で余分な権限を制限しています。
          -->

          <div class="border-2 border-dashed border-ink/10 p-10 text-center">
            <p class="text-xs text-ink-muted font-body">
              Google フォームを設定<br/>
            </p>
          </div>

          <!--
          <iframe
            src="https://docs.google.com/forms/d/e/YOUR_GOOGLE_FORM_ID/viewform?embedded=true"
            width="100%"
            height="800"
            class="border-0"
            title="お問い合わせフォーム"
            sandbox="allow-scripts allow-forms allow-same-origin allow-popups"
            loading="lazy"
          >
            読み込んでいます…
          </iframe>
          -->
        </div>

        <!-- 注意事項 -->
        <div class="mt-8 p-6 border border-gold bg-gold/5">
          <h3 class="text-xs font-body font-medium tracking-widest uppercase text-ink-muted mb-4">Notice</h3>
          <ul class="space-y-2">
            {[
              "営業時間外のお問い合わせは翌営業日以降のご対応となります。",
              "お急ぎの場合はお電話でのご連絡をおすすめいたします。",
              "いただいた個人情報はお問い合わせ対応以外の目的では使用しません。",
              "メールアドレスの入力間違いにご注意ください。",
            ].map(t => (
              <li class="flex items-start gap-2.5 text-xs text-ink-muted font-body">
                <span class="text-gold mt-0.5 flex-shrink-0"><Icon name="chevron-right" class="w-3 h-3" /></span>
                {t}
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- 店舗情報 -->
  <section class="sec bg-ink">
    <div class="container-site">
      <div class="max-w-2xl mx-auto">
        <span class="section-label text-gold/70">Shop Info</span>
        <h2 class="font-display text-2xl text-cream mb-8">店舗情報</h2>
        <dl class="divide-y divide-cream/10">
          {[
            { dt: "店舗名",   dd: `${SITE.name}（${SITE.nameJa}）` },
            { dt: "住所",     dd: `〒${SITE.postalCode} ${SITE.address}` },
            { dt: "電話",     dd: SITE.tel },
            { dt: "営業時間", dd: `${SITE.hours.weekday} / ${SITE.hours.weekend}` },
            { dt: "定休日",   dd: SITE.closed },
          ].map(({ dt, dd }) => (
            <div class="flex gap-6 py-4">
              <dt class="w-20 flex-shrink-0 text-[11px] text-cream/30 font-body tracking-wider pt-0.5">{dt}</dt>
              <dd class="text-sm text-cream/70 font-body">{dd}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>
</Layout>
