---
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/Icon.astro";
import { SITE } from "@/lib/config";

const mapQuery = encodeURIComponent(SITE.address);
const mapSrc   = `https://www.google.com/maps?q=${mapQuery}&output=embed`;

const routes = [
  { icon: "train" as const, label: "Train", title: "電車でお越しの場合",   body: "JR・東急各線「渋谷駅」ハチ公口より徒歩約5分。" },
  { icon: "car"   as const, label: "Car",   title: "お車でお越しの場合",   body: "首都高速3号渋谷線「渋谷出口」より約5分。店舗近隣にコインパーキングあり。" },
  { icon: "bus"   as const, label: "Bus",   title: "バスでお越しの場合",   body: "都営バス「神宮前」バス停下車、徒歩約2分。" },
];
---

<Layout
  title="Access | Trim Studio"
  description="Trim Studio へのアクセス方法。渋谷駅より徒歩5分。"
>
  <!-- ページヘッダー -->
  <section class="py-20 md:py-24 bg-ink">
    <div class="container-site">
      <span class="section-label text-gold/70">Location & Hours</span>
      <h1 class="font-display text-5xl md:text-6xl text-cream font-semibold leading-tight">Access</h1>
    </div>
  </section>

  <!-- 店舗情報 + アクセス方法 -->
  <section class="sec bg-cream">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- 店舗情報 -->
        <div>
          <span class="section-label">Shop Info</span>
          <h2 class="section-title mb-8">店舗情報</h2>

          <dl class="divide-y divide-ink/10">
            {[
              { dt: "店舗名",   dd: `${SITE.name}（${SITE.nameJa}）` },
              { dt: "住所",     dd: `〒${SITE.postalCode}<br/>${SITE.address}` },
              { dt: "電話",     dd: `<a href="${SITE.telHref}" class="hover:text-gold transition-colors">${SITE.tel}</a>` },
              { dt: "営業時間", dd: `${SITE.hours.weekday}<br/>${SITE.hours.weekend}` },
              { dt: "定休日",   dd: SITE.closed },
              { dt: "駐車場",   dd: "近隣コインパーキングをご利用ください" },
            ].map(({ dt, dd }) => (
              <div class="flex gap-6 py-4">
                <dt class="w-20 flex-shrink-0 text-[11px] font-body text-ink-muted tracking-wider pt-0.5">{dt}</dt>
                <dd class="text-sm font-body text-ink leading-relaxed" set:html={dd} />
              </div>
            ))}
          </dl>

          <div class="mt-8">
            <a href={SITE.telHref} class="btn-outline-dark inline-flex items-center gap-2.5">
              <Icon name="phone" class="w-4 h-4" />
              電話でお問い合わせ
            </a>
          </div>
        </div>

        <!-- アクセス方法 -->
        <div>
          <span class="section-label">How to Get Here</span>
          <h2 class="section-title mb-8">アクセス方法</h2>
          <div class="space-y-4">
            {routes.map(r => (
              <div class="bg-cream-dark p-5 border-l-2 border-gold/40 hover:border-gold transition-colors duration-200">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-gold"><Icon name={r.icon} class="w-4 h-4" /></span>
                  <span class="text-[9px] tracking-widest2 uppercase text-ink-muted font-body">{r.label}</span>
                  <span class="font-display text-base text-ink">{r.title}</span>
                </div>
                <p class="text-xs text-ink-muted font-body leading-relaxed pl-7">{r.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Google マップ -->
  <section class="bg-cream-dark py-0">
    <div class="border-y border-ink/10">
      <iframe
        src={mapSrc}
        width="100%"
        height="420"
        class="border-0 block"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Trim Studio の地図"
        sandbox="allow-scripts allow-same-origin"
      ></iframe>
    </div>
  </section>

  <!-- 外観写真 -->
  <section class="sec bg-cream">
    <div class="container-site">
      <span class="section-label">Exterior</span>
      <h2 class="section-title mb-8">店舗外観</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {["外観 1", "外観 2"].map(l => (
          <div class="aspect-video bg-cream-dark border border-ink/5 flex items-center justify-center">
            <span class="text-xs text-ink/25 font-body">{l}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="sec bg-ink">
    <div class="container-site text-center">
      <span class="section-label text-gold">Reservation</span>
      <h2 class="font-display text-3xl text-cream mb-3">ご予約・お問い合わせ</h2>
      <div class="divider"></div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href={SITE.telHref} class="inline-flex items-center justify-center gap-2 btn-outline-light">
          <Icon name="phone" class="w-4 h-4" />
          {SITE.tel}
        </a>
        <a href="/contact" class="btn-outline-light">Contact Form</a>
      </div>
    </div>
  </section>
</Layout>
