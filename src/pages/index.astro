---
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/Icon.astro";
import { SITE } from "@/lib/config";
import { getBlogList, getCategoryName } from "@/lib/microcms";

export const prerender = true;

const { contents: latestPosts } = await getBlogList(3);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString("ja-JP", {
    year: "numeric", month: "2-digit", day: "2-digit",
  });
}
---

<Layout
  title="Trim Studio | 東京都渋谷区のバーバーショップ"
  description="東京都渋谷区のバーバーショップ「Trim Studio」。カット・シェービングを中心に、精確な技術で一人ひとりのスタイルを仕上げます。"
>

  <!-- ━━━━━━━━ HERO ━━━━━━━━ -->
  <section class="relative min-h-[70vh] md:min-h-[80vh] flex flex-col justify-center md:justify-end bg-ink overflow-hidden">
    <!-- 背景グラデーション装飾 -->
    <div class="absolute inset-0 opacity-20 pointer-events-none"
        style="background: radial-gradient(ellipse 70% 60% at 70% 40%, #c8a96e22 0%, transparent 70%);">
    </div>
    <!-- 細かい縦線 装飾 -->
    <div class="absolute top-0 left-[12%] w-px h-full bg-cream/5 pointer-events-none"></div>
    <div class="absolute top-0 right-[18%] w-px h-full bg-cream/5 pointer-events-none"></div>

    <div class="container-site pb-20 md:pb-28 animate-fade-up">
      <!-- タグライン -->
      <p class="section-label text-gold mb-6">{SITE.tagline}</p>

      <!-- メイン見出し -->
      <h1 class="font-display text-[clamp(3.5rem,10vw,7rem)] font-semibold text-cream leading-[0.9] tracking-tight mb-8">
        Trim<br/>Studio
      </h1>

      <p class="text-cream/60 text-sm leading-relaxed max-w-xs mb-10 font-body">
        ひとりひとりの個性に向き合い、<br/>
        細部まで丁寧に仕上げるバーバーショップ。
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/menu"    class="btn-outline-light">View Menu</a>
        <a href="/contact" class="btn-outline-light">Book Now</a>
      </div>
    </div>

    <!-- スクロール インジケーター -->
    <div class="absolute bottom-8 right-8 flex flex-col items-center gap-2 text-cream/30">
      <span class="text-[9px] tracking-widest2 uppercase rotate-90 origin-center translate-x-4">Scroll</span>
      <span class="w-px h-10 bg-cream/20"></span>
    </div>
  </section>


  <!-- ━━━━━━━━ INFO BAR ━━━━━━━━ -->
  <section class="bg-gold/10 border-y border-gold/20">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-gold/20">
        {[
          { icon: "map-pin" as const, label: "Access", value: "渋谷駅より徒歩5分" },
          { icon: "clock"   as const, label: "Hours",  value: "火〜金 10:00–20:00 / 土日 10:00–19:00" },
          { icon: "calendar" as const, label: "Closed", value: "月曜日 / 第1火曜日" },
        ].map(item => (
          <div class="flex items-center gap-4 py-5 px-2">
            <span class="text-gold flex-shrink-0">
              <Icon name={item.icon} class="w-5 h-5" />
            </span>
            <div>
              <p class="text-[9px] tracking-widest2 uppercase text-ink-muted font-body mb-0.5">{item.label}</p>
              <p class="text-xs text-ink font-body">{item.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━ ABOUT ━━━━━━━━ -->
  <section class="sec bg-cream">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">

        <!-- テキスト -->
        <div>
          <span class="section-label">About Us</span>
          <h2 class="section-title mb-2">理容の本質を、<br/>ひとつひとつに。</h2>
          <div class="divider mx-0"></div>
          <div class="space-y-4 text-sm text-ink-muted leading-relaxed font-body">
            <p>
              Trim Studioは、「整える」という行為を通じてお客様の日常をより豊かにすることを目指すバーバーショップです。
            </p>
            <p>
              ハサミ一本、カミソリ一刀に精確さと誠実さを込めて、あなたらしいスタイルを丁寧に仕上げます。
              流行を追うだけでなく、骨格・髪質・生活スタイルを考慮した提案を心がけています。
            </p>
            <p>
              清潔で落ち着いた空間で、リラックスしながらお任せください。
            </p>
          </div>
        </div>

        <!-- 写真プレースホルダー -->
        <div class="grid grid-cols-2 gap-3">
          {["店内", "スタイル", "シェービング", "外観"].map(l => (
            <div class="aspect-square bg-cream-dark border border-ink/5 flex items-center justify-center">
              <span class="text-[11px] text-ink/30 font-body">{l}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━ PHILOSOPHY ━━━━━━━━ -->
  <section class="sec bg-ink">
    <div class="container-site">
      <div class="max-w-2xl mx-auto text-center">
        <span class="section-label text-gold/70">Our Philosophy</span>
        <blockquote class="font-display text-2xl md:text-3xl text-cream leading-snug italic font-light mt-4 mb-8">
          "A good haircut is not just about appearance—<br class="hidden md:block"/>
          it's about how you feel."
        </blockquote>
        <div class="divider"></div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-10 text-left">
          {[
            { num: "01", title: "精確な技術", body: "長年の経験と継続的な学習から生まれた、確かなカット技術。" },
            { num: "02", title: "丁寧な接客", body: "カウンセリングを大切にし、お客様の理想を丁寧に引き出します。" },
            { num: "03", title: "清潔な環境", body: "器具の消毒・衛生管理を徹底した、安心できる空間を提供します。" },
          ].map(item => (
            <div>
              <p class="font-display text-4xl text-gold font-semibold mb-2">{item.num}</p>
              <h3 class="font-display text-lg text-cream mb-2">{item.title}</h3>
              <p class="text-xs text-cream/50 leading-relaxed font-body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━ MENU PREVIEW ━━━━━━━━ -->
  <section class="sec bg-cream-dark">
    <div class="container-site">
      <div class="text-center mb-12">
        <span class="section-label">Services</span>
        <h2 class="section-title">主なメニュー</h2>
        <div class="divider"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-ink/10 border border-ink/10">
        {[
          { name: "カット",               price: "¥4,000", desc: "骨格・髪質に合わせた丁寧なカット。" },
          { name: "シェービング",          price: "¥2,500", desc: "伝統技法によるすっきりとした仕上がり。" },
          { name: "カット + シェービング", price: "¥6,000", desc: "トータルケアでより洗練されたスタイルに。" },
        ].map(item => (
          <div class="bg-cream p-8 text-center hover:bg-cream-dark transition-colors duration-200">
            <p class="font-display text-xl text-ink mb-1">{item.name}</p>
            <p class="text-2xl font-display font-semibold text-gold mb-4">{item.price}</p>
            <p class="text-xs text-ink-muted leading-relaxed font-body">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/menu" class="btn-outline-dark">Full Menu</a>
      </div>
    </div>
  </section>



  <!-- ━━━━━━━━ BLOG PREVIEW ━━━━━━━━ -->
  <section class="sec bg-cream">
    <div class="container-site">
      <div class="flex items-end justify-between mb-10 gap-4">
        <div>
          <span class="section-label">From the Blog</span>
          <h2 class="section-title">最新の記事</h2>
        </div>
        <a
          href="/blog"
          class="hidden sm:inline-flex items-center gap-1.5 text-[10px] tracking-widest2 uppercase font-body text-ink-muted hover:text-ink transition-colors duration-200 flex-shrink-0"
        >
          All Posts
          <Icon name="arrow-right" class="w-3.5 h-3.5" />
        </a>
      </div>

      {latestPosts.length > 0 ? (
        <>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {latestPosts.map((post) => {
              const cat = getCategoryName(post.category);
              return (
                <a
                  href={`/blog/${post.id}`}
                  class="group flex flex-col bg-white border border-ink/8 hover:border-gold/50 transition-colors duration-200 overflow-hidden"
                >
                  {post.eyecatch ? (
                    <div class="aspect-video overflow-hidden bg-cream-dark">
                      <img
                        src={post.eyecatch.url + "?w=600&q=80"}
                        alt={post.title}
                        width="600"
                        height="338"
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
                      />
                    </div>
                  ) : (
                    <div class="aspect-video bg-cream-dark flex items-center justify-center">
                      <Icon name="scissors" class="w-7 h-7 text-ink/15" />
                    </div>
                  )}
                  <div class="flex flex-col flex-1 p-5">
                    <div class="flex items-center gap-3 mb-2">
                      <time class="text-[10px] text-ink-muted font-body tracking-wider">
                        {formatDate(post.publishedAt)}
                      </time>
                      {cat && (
                        <span class="inline-block px-2 py-0.5 text-[9px] tracking-widest uppercase font-body bg-ink text-cream">
                          {cat}
                        </span>
                      )}
                    </div>
                    <h3 class="font-display text-base text-ink leading-snug group-hover:text-gold transition-colors duration-200 flex-1">
                      {post.title}
                    </h3>
                    <span class="inline-flex items-center gap-1 text-[10px] tracking-widest uppercase text-gold font-body mt-4">
                      Read More <Icon name="arrow-right" class="w-3 h-3" />
                    </span>
                  </div>
                </a>
              );
            })}
          </div>

          <div class="text-center mt-8 sm:hidden">
            <a href="/blog" class="btn-outline-dark">ブログ一覧を見る</a>
          </div>
        </>
      ) : (
        <div class="text-center py-16 border border-dashed border-ink/10">
          <p class="text-xs text-ink-muted font-body">
            microCMS にブログ記事を追加するとここに表示されます。
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- ━━━━━━━━ CTA ━━━━━━━━ -->
  <section class="sec bg-ink">
    <div class="container-site text-center">
      <span class="section-label text-gold/70">Reservation</span>
      <h2 class="font-display text-3xl md:text-4xl text-cream mb-3">ご予約・お問い合わせ</h2>
      <div class="divider"></div>
      <p class="text-xs text-cream/50 mb-10 font-body">お電話またはフォームよりお気軽にどうぞ</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={SITE.telHref}
          class="inline-flex items-center justify-center gap-2.5 px-9 py-3 bg-cream text-ink text-xs tracking-widest2 font-body font-medium hover:bg-cream-dark transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold"
        >
          <Icon name="phone" class="w-4 h-4" />
          {SITE.tel}
        </a>
        <a href="/contact" class="btn-outline-light">Contact Form</a>
      </div>
    </div>
  </section>

</Layout>
