---
import { SITE } from "@/lib/config";
const year = new Date().getFullYear();

const nav = [
  { href: "/",        label: "Top"     },
  { href: "/menu",    label: "Menu"    },
  { href: "/blog",    label: "Blog"    },
  { href: "/access",  label: "Access"  },
  { href: "/contact", label: "Contact" },
];
---

<footer class="bg-ink text-cream/60 relative overflow-hidden">
  <!-- Decorative vertical lines -->
  <div class="absolute top-0 left-[30%] w-px h-full bg-cream/[0.03] pointer-events-none"></div>
  <div class="absolute top-0 right-[20%] w-px h-full bg-cream/[0.03] pointer-events-none"></div>

  <!-- Top accent line (gold) -->
  <div class="w-full h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>

  <div class="container-site py-16 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-12">

      <!-- ブランド（左） -->
      <div class="md:col-span-5">
        <p class="font-display text-2xl text-cream tracking-widest font-semibold mb-1">
          TRIM STUDIO
        </p>
        <p class="text-[10px] tracking-widest2 text-gold/70 uppercase mb-6 font-body">
          {SITE.tagline}
        </p>

        <!-- Gold divider -->
        <div class="w-8 h-px bg-gold/40 mb-6"></div>

        <address class="not-italic text-xs space-y-2 leading-relaxed font-body">
          <p class="text-cream/40">〒{SITE.postalCode}</p>
          <p>{SITE.address}</p>
          <p class="mt-3">
            <a href={SITE.telHref} class="hover:text-cream transition-colors duration-200 text-cream/60">
              TEL {SITE.tel}
            </a>
          </p>
          <p class="mt-3 text-cream/40">{SITE.hours.weekday}</p>
          <p class="text-cream/40">{SITE.hours.weekend}</p>
          <p class="text-cream/25">定休日：{SITE.closed}</p>
        </address>
      </div>

      <!-- ナビ（中） -->
      <div class="md:col-span-3 md:col-start-7">
        <p class="text-[10px] tracking-widest2 text-gold/60 uppercase mb-6 font-body">Navigation</p>
        <ul class="space-y-3">
          {nav.map(l => (
            <li>
              <a
                href={l.href}
                class="text-[11px] tracking-widest uppercase font-body hover:text-cream transition-colors duration-200 flex items-center gap-2 group"
              >
                <span class="w-3 h-px bg-gold/30 group-hover:w-5 group-hover:bg-gold transition-all duration-300"></span>
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- SNS（右） -->
      <div class="md:col-span-3 md:col-start-10">
        <p class="text-[10px] tracking-widest2 text-gold/60 uppercase mb-6 font-body">Follow Us</p>
        <a
          href={SITE.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 text-xs hover:text-cream transition-colors duration-200 group"
          aria-label="Instagram"
        >
          <span class="w-8 h-8 border border-cream/15 group-hover:border-gold flex items-center justify-center transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </span>
          @trimstudio
        </a>

        <!-- 予約ボタン -->
        <div class="mt-8">
          <a href="/contact" class="btn-outline-light text-[10px]">
            Book Now
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-cream/8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-[11px] text-cream/25 font-body">
        &copy; {year} Trim Studio. All rights reserved.
      </p>
      <p class="text-[10px] text-cream/15 tracking-widest uppercase font-body">
        Precision Barbering · Tokyo
      </p>
    </div>
  </div>
</footer>
