---
import { SITE } from "@/lib/config";
const year = new Date().getFullYear();

const nav = [
  { href: "/",        label: "Top" },
  { href: "/menu",    label: "Menu" },
  { href: "/blog",    label: "Blog" },
  { href: "/access",  label: "Access" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="bg-ink text-cream/70">
  <div class="container-site py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">

      <!-- ブランド -->
      <div>
        <p class="font-display text-xl text-cream tracking-widest font-semibold mb-1">TRIM STUDIO</p>
        <p class="text-[10px] tracking-widest2 text-gold uppercase mb-5">{SITE.tagline}</p>
        <address class="not-italic text-xs space-y-1.5 leading-relaxed">
          <p>〒{SITE.postalCode}　{SITE.address}</p>
          <p>
            <a href={SITE.telHref} class="hover:text-cream transition-colors duration-200">
              TEL {SITE.tel}
            </a>
          </p>
          <p class="mt-3">{SITE.hours.weekday}</p>
          <p>{SITE.hours.weekend}</p>
          <p class="text-cream/40">定休日：月曜日</p>
        </address>
      </div>

      <!-- Nav -->
      <div>
        <p class="text-[10px] tracking-widest2 text-gold uppercase mb-5">Navigation</p>
        <ul class="space-y-2.5">
          {nav.map(l => (
            <li>
              <a href={l.href} class="text-xs tracking-widest uppercase hover:text-cream transition-colors duration-200">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- SNS -->
      <div>
        <p class="text-[10px] tracking-widest2 text-gold uppercase mb-5">Follow Us</p>
        <a
          href={SITE.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-xs hover:text-cream transition-colors duration-200"
          aria-label="Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          @trimstudio
        </a>
      </div>
    </div>

    <div class="border-t border-cream/10 pt-6 text-center">
      <p class="text-[11px] text-cream/30">&copy; {year} Trim Studio. All rights reserved.</p>
    </div>
  </div>
</footer>
