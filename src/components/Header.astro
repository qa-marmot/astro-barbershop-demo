---
const nav = [
  { href: "/",        label: "Top"     },
  { href: "/menu",    label: "Menu"    },
  { href: "/blog",    label: "Blog"    },
  { href: "/access",  label: "Access"  },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-400"
  style="background: rgba(28,25,23,0.72); backdrop-filter: blur(6px);"
>
  <div class="container-site">
    <div class="flex items-center justify-between h-[70px]">

      <!-- ロゴ -->
      <a
        href="/"
        class="font-display text-xl font-semibold tracking-widest text-cream transition-colors duration-300"
      >
        TRIM STUDIO
      </a>

      <!-- デスクトップ nav -->
      <nav class="hidden md:flex items-center gap-9" aria-label="メインナビゲーション">
        {nav.map(l => (
          <a
            href={l.href}
            class={`text-[11px] font-body font-medium tracking-widest2 uppercase transition-colors duration-300 ${
              currentPath === l.href
                ? 'text-gold'
                : 'text-cream/85 hover:text-cream'
            }`}
          >
            {l.label}
          </a>
        ))}
      </nav>

      <!-- Book Now CTA（デスクトップのみ） -->
      <a
        href="/contact"
        class="hidden md:inline-block text-[10px] tracking-widest2 uppercase font-body px-5 py-2 border border-cream/45 text-cream/85 hover:border-gold hover:text-gold transition-all duration-300"
      >
        Book Now
      </a>

      <!-- モバイル ハンバーガー -->
      <button
        id="menu-btn"
        class="md:hidden flex items-center justify-center w-9 h-9 text-cream focus:outline-none focus-visible:ring-2 focus-visible:ring-gold"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="メニューを開く"
      >
        <span id="icon-menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
          </svg>
        </span>
        <span id="icon-close" class="hidden">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
          </svg>
        </span>
      </button>
    </div>
  </div>

  <!-- モバイル メニュー -->
  <div
    id="mobile-nav"
    class="md:hidden hidden backdrop-blur-md border-t border-cream/10"
    style="background: rgba(28,25,23,0.97);"
    role="navigation"
    aria-label="モバイルナビゲーション"
  >
    {nav.map(l => (
      <a
        href={l.href}
        class="block px-7 py-4 text-[11px] font-body tracking-widest2 uppercase text-cream/55 hover:text-cream hover:bg-cream/5 border-b border-cream/5 transition-colors duration-150"
      >
        {l.label}
      </a>
    ))}
    <div class="px-7 py-5">
      <a href="/contact" class="btn-outline-light text-center block text-[10px]">
        Book Now
      </a>
    </div>
  </div>
</header>

<script>
  const btn    = document.getElementById("menu-btn")!;
  const mNav   = document.getElementById("mobile-nav")!;
  const iMenu  = document.getElementById("icon-menu")!;
  const iClose = document.getElementById("icon-close")!;
  const header = document.getElementById("site-header")!;

  btn.addEventListener("click", () => {
    const open = mNav.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(open));
    iMenu.classList.toggle("hidden", open);
    iClose.classList.toggle("hidden", !open);
  });

  const update = () => {
    const scrolled = window.scrollY > 60;
    if (scrolled) {
      // スクロール後：不透明度を上げ、ボーダーを追加
      header.style.background      = "rgba(28,25,23,0.97)";
      header.style.backdropFilter  = "blur(12px)";
      header.style.borderBottom    = "1px solid rgba(250,247,242,0.08)";
      header.style.boxShadow       = "0 4px 24px rgba(0,0,0,0.35)";
    } else {
      // ページ最上部：半透明ダーク（常時可読）
      header.style.background      = "rgba(28,25,23,0.72)";
      header.style.backdropFilter  = "blur(6px)";
      header.style.borderBottom    = "none";
      header.style.boxShadow       = "none";
    }
  };

  window.addEventListener("scroll", update, { passive: true });
  update();
</script>
